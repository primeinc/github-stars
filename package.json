{
  "name": "github-stars",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "gate": "tsx src/gate/cli.ts",
    "repro:taxonomy": "tsx src/repro-taxonomy.ts",
    "normalize": "tsx src/cli-normalize.ts",
    "validate": "tsx src/cli-validate.ts",
    "auth:doctor": "tsx src/auth/setup-doctor.ts",
    "fetch:stars": "tsx src/fetch/cli.ts",
    "sync:stars": "tsx src/sync/cli.ts"
  },
  "devDependencies": {
    "@exodus/schemasafe": "^1.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "@octokit/auth-app": "^8.2.0",
    "@octokit/core": "^7.0.6",
    "@octokit/plugin-request-log": "^6.0.0",
    "@octokit/plugin-retry": "^8.1.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.1.0"
  },
  "pnpm": {
    "//": "esbuild ships postinstall scripts that fetch a platform binary. Allow it explicitly so a future pnpm major (which exits 1 on ignored builds, see .sisyphus/proofs/02B-failed-runs.md) does not break CI.",
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
