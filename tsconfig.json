{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./generated/test-cache/tsc-root.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "tests/**/*.ts",
    "scripts/**/*.ts",
    "github-stars.paths.config.ts",
    "eslint.config.ts",
    "knip.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "generated",
    "web",
    "scripts/generate-readmes.js",
    "scripts/migrate-data.js",
    "scripts/migrate-data-regex.js"
  ]
}
